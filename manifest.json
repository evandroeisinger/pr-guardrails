{
  "manifest_version": 3,
  "name": "PR Merge Guardrails",
  "version": "1.0.0",
  "description": "Hide the GitHub PR merge button on configured days, or when the PR was opened by someone other than you.",
  "permissions": ["storage"],
  "content_scripts": [
    {
      "matches": ["https://github.com/*/*/pull/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html",
  "action": {
    "default_title": "PR Merge Guardrails",
    "default_popup": "options.html"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
